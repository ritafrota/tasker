enum EstadoSprint {
  pendente
  finalizada
}

model Sprint {
  id        Int    @id @default(autoincrement())
  nome      String

  inicio DateTime
  fim DateTime

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  projetoId Int
  projeto Projeto @relation(fields: [projetoId], references: [id])

  estado EstadoSprint @default(pendente)

  tarefas Tarefa[]
}
