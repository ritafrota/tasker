enum EstadoTarefa {
  A_FAZER
  FAZENDO
  FEITO
}

enum Prioriodade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Tarefa {
  id        Int    @id @default(autoincrement())
  nome      String
  descricao String

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario   Usuario[]

  prioridade Prioriodade
  
  duracao Int

  sprintId Int
  sprint   Sprint @relation(fields: [sprintId], references: [id])

  estado EstadoTarefa @default(A_FAZER)
}
